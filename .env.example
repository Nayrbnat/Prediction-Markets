# ---- Database (required) -------------------------------------------------
# Use a POOLED DSN on serverless (Neon pooler / pgbouncer).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local Docker Compose (matches docker-compose.yml defaults):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/predmarket
# If host port 5432 is taken, start with a different host port:
#   DB_PORT=5434 docker compose up   (then use ...@localhost:5434/predmarket)

# Supabase: use the TRANSACTION POOLER connection string (port 6543, NOT 5432).
# asyncpg is configured with statement_cache_size=0 to disable prepared statements,
# which are not supported in pgbouncer/Supavisor transaction mode.
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-[region].pooler.supabase.com:6543/postgres

# ---- What to ingest ------------------------------------------------------
INGEST_TOPICS=fed rate decision,btc price,us recession,sp500 year end
HIGH_PRIORITY_TOPICS=fed rate decision,us recession
# Optional JSON maps (topic -> category; topic -> Kalshi series ticker)
CATEGORY_MAP={"fed rate decision":"monetary-policy","btc price":"crypto"}
# Kalshi has NO keyword search. Resolve each topic to series two ways:
#  1) KALSHI_SERIES_MAP: topic -> series ticker (string) or list of tickers.
#     Reliable, explicit. Verified live: "fed rate decision" -> KXFEDDECISION.
#  2) KALSHI_CATEGORY_MAP: topic -> Kalshi category; auto keyword-matches series
#     titles within that category (fallback when no series map entry exists).
#     Categories: Economics, Politics, Financials, Elections, World, Companies,
#     Health, Science and Technology, Climate and Weather, Sports, Social, ...
KALSHI_SERIES_MAP={"fed rate decision":"KXFEDDECISION"}
KALSHI_CATEGORY_MAP={"us recession":"Economics","btc price":"Financials"}
PER_TOPIC_LIMIT=50

# ---- Behaviour thresholds ------------------------------------------------
RETENTION_DAYS=15          # purge untracked rows older than this many days
MATERIAL_CHANGE=0.01       # min |delta| (prob, 0..1) to write a change-log row (1pp)
THIN_VOLUME=1000           # below this 24h volume -> low-confidence flag
THIN_SPREAD=0.05           # above this bid/ask spread (0..1) -> low-confidence flag
LIVE_TTL_SECONDS=900       # /analyze serves from store if fresher than this, else live top-up

# ---- Venue endpoints (verify per DATA_SOURCES.md) ------------------------
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# ---- Cron + logging ------------------------------------------------------
CRON_SECRET=change-me
LOG_LEVEL=INFO
LOG_FORMAT=json            # "json" for prod, "console" for local dev

# ---- v2 only (leave blank in v1; on-chain smart-money is deferred) -------
POLYGON_RPC_URL=
CTF_EXCHANGE_ADDRESS=
