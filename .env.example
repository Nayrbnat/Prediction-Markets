# ---- Database (required) -------------------------------------------------
# Use a POOLED DSN on serverless (Neon pooler / pgbouncer).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local Docker Compose (matches docker-compose.yml defaults):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/predmarket
# If host port 5432 is taken, start with a different host port:
#   DB_PORT=5434 docker compose up   (then use ...@localhost:5434/predmarket)

# Supabase: use the TRANSACTION POOLER connection string (port 6543, NOT 5432).
# asyncpg is configured with statement_cache_size=0 to disable prepared statements,
# which are not supported in pgbouncer/Supavisor transaction mode.
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-[region].pooler.supabase.com:6543/postgres

# ---- What to ingest ------------------------------------------------------
INGEST_TOPICS=fed rate decision,btc price,eth price,us recession,sp500 year end
HIGH_PRIORITY_TOPICS=fed rate decision,us recession
# Optional JSON maps (topic -> category; topic -> Kalshi series ticker)
CATEGORY_MAP={"fed rate decision":"monetary-policy","btc price":"crypto","eth price":"crypto"}
# Kalshi has NO keyword search. Resolve each topic to series two ways:
#  1) KALSHI_SERIES_MAP: topic -> series ticker (string) or list of tickers.
#     Reliable, explicit. Verified live: "fed rate decision" -> KXFEDDECISION.
#  2) KALSHI_CATEGORY_MAP: topic -> Kalshi category; auto keyword-matches series
#     titles within that category (fallback when no series map entry exists).
#     Categories: Economics, Politics, Financials, Elections, World, Companies,
#     Health, Science and Technology, Climate and Weather, Sports, Social, ...
# Verified live 2026-06-24: crypto price series live under the "Crypto" category as
# KXBTCD ("Bitcoin price Above/below") / KXETHD ("Ethereum price Above/below"); their
# nested markets are terminal "$X or above" thresholds (yes_sub_title) — what the
# relative-value matcher needs. (NOT in the "Financials" category.)
KALSHI_SERIES_MAP={"fed rate decision":"KXFEDDECISION","btc price":["KXBTCD"],"eth price":["KXETHD"]}
KALSHI_CATEGORY_MAP={"us recession":"Economics"}
PER_TOPIC_LIMIT=50

# ---- Behaviour thresholds ------------------------------------------------
RETENTION_DAYS=15          # purge untracked rows older than this many days
MATERIAL_CHANGE=0.01       # min |delta| (prob, 0..1) to write a change-log row (1pp)
THIN_VOLUME=1000           # below this 24h volume -> low-confidence flag
THIN_SPREAD=0.05           # above this bid/ask spread (0..1) -> low-confidence flag
LIVE_TTL_SECONDS=900       # /analyze serves from store if fresher than this, else live top-up

# ---- Venue endpoints (verify per DATA_SOURCES.md) ------------------------
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2

# ---- Cron + logging ------------------------------------------------------
CRON_SECRET=change-me
LOG_LEVEL=INFO
LOG_FORMAT=json            # "json" for prod, "console" for local dev

# ---- Daily digest --------------------------------------------------------
# Set DIGEST_ENABLED=true to send the email after each cron run.
# MOVER_THRESHOLD: min |delta| (0..1) for a market to appear in the movers
#   section — default is 0.10 (10 percentage points day-over-day).
MOVER_THRESHOLD=0.10
DIGEST_ENABLED=false
DIGEST_FROM=prediction-markets@example.com
DIGEST_TO=you@example.com,colleague@example.com   # comma-separated

# ---- CME Fed Funds futures (relative-value signal) -----------------------
# Compares prediction-market probabilities against the Fed-funds-futures-implied
# (ZQ) probability for the SAME FOMC meeting, and surfaces the gap in the digest.
# Set CME_ENABLED=true to ingest the `cme` venue (free Yahoo ZQ data + NY Fed EFFR).
CME_ENABLED=false
CME_TOPICS=fed rate decision          # topics the CME source serves (CSV)
CME_MEETING_HORIZON=2                  # number of upcoming FOMC meetings to price
RV_GAP_THRESHOLD=0.05                  # |market − futures| (0..1) to flag a divergence (5pp)
# FOMC announcement dates (2nd day of each meeting), ISO, CSV. Source picks the next N.
# 2026 schedule (verify/extend from federalreserve.gov/monetarypolicy/fomccalendars.htm):
FOMC_MEETINGS=2026-01-28,2026-03-18,2026-04-29,2026-06-17,2026-07-29,2026-09-16,2026-10-28,2026-12-09
# Data endpoints (free, no key) — override only if mirroring:
# YAHOO_CHART_BASE_URL=https://query1.finance.yahoo.com
# NYFED_RATES_BASE_URL=https://markets.newyorkfed.org

# ---- Crypto price thresholds (Deribit options, relative value) -----------
# Compares prediction-market 'will BTC/ETH reach $X' probabilities against the
# options-implied (Breeden-Litzenberger) risk-neutral P(above) from Deribit (free, no
# key). Targets are "strike@expirytoken" pairs using Deribit's own expiry codes.
CRYPTO_GAP_THRESHOLD=0.05              # |market − options| (0..1) to flag (5pp)
# DERIBIT_BASE_URL=https://www.deribit.com
# DYNAMIC TARGETING (default): when enabled, each run derives the (strike, expiry) to
# query Deribit from the live Polymarket/Kalshi terminal markets ("above $X on [date]" /
# "$X or above"); barrier markets ("reach"/"hit"/"max") are skipped. No targets to maintain.
# BTC_TARGETS/ETH_TARGETS are OPTIONAL manual supplements ("strike@deribitExpiryToken",
# e.g. 100000@26DEC26) — usually leave blank.
BTC_ENABLED=false
BTC_TOPICS=btc price
BTC_TARGETS=
ETH_ENABLED=false
ETH_TOPICS=eth price
ETH_TARGETS=

# ---- ECB rate decision (€STR futures, relative value) --------------------
# ⚠️ DEFERRED (verified 2026-06-24): no FREE data supports a correct ECB signal. ESR*.CME
# is CME's 3-MONTH compounded €STR (wrong for the 1-month-average rate-step math); the
# 1-month €STR (ICE) has no free feed; and 3-month strip math needs the serial/monthly €STR
# contracts to isolate a meeting, which the free Yahoo feed lacks (quarterly only; a quarter
# spans ~2 ECB meetings -> under-determined). Keep disabled until a PAID €STR feed is wired.
# The €STR rate (ECB SDMX) + ECB markets on Polymarket already work; only the futures leg is
# blocked. Dates below are correct for when it is fixed.
ECB_ENABLED=false
ECB_TOPICS=ecb rate decision
ECB_MEETING_HORIZON=2
# ECB Governing Council monetary-policy decision dates (Thursday announcement), ISO, CSV.
# 2026 upcoming verified on ecb.europa.eu (extend with the full-year list as needed):
ECB_MEETINGS=2026-07-23,2026-09-10,2026-10-29,2026-12-17
# ECB_RATES_BASE_URL=https://data-api.ecb.europa.eu

# ---- SMTP (for digest emails) --------------------------------------------
# Gmail app-password example (generate at myaccount.google.com → Security → App passwords):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=xxxx xxxx xxxx xxxx     # 16-char app password, no quotes
# Leave SMTP_HOST blank to fall back to ConsoleEmailSender (prints to stdout).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ---- v2 only (leave blank in v1; on-chain smart-money is deferred) -------
POLYGON_RPC_URL=
CTF_EXCHANGE_ADDRESS=
